import os
import cv2
import numpy as np
import pickle

# ---------------- PATHS ----------------
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
VIDEO_FOLDER = os.path.abspath(os.path.join(BASE_DIR, "../data/videos"))
OUTPUT_DB = os.path.join(BASE_DIR, "face_db_pi.pkl")

# ---------------- SETTINGS ----------------
FRAME_SKIP = 10
MAX_EMB = 200
IMG_SIZE = 100

database = {}

# ---------------- FACE DETECTOR ----------------
face_cascade = cv2.CascadeClassifier(
    cv2.data.haarcascades + "haarcascade_frontalface_default.xml"
)

# ---------------- AUGMENTATION ----------------
def augment_face(face):
    augmented = []

    augmented.append(face)

    bright = cv2.convertScaleAbs(face, alpha=1.2, beta=30)
    augmented.append(bright)

    dark = cv2.convertScaleAbs(face, alpha=0.8, beta=-30)
    augmented.append(dark)

    flip = cv2.flip(face, 1)
    augmented.append(flip)

    return augmented

# ---------------- BETTER EMBEDDING ----------------
def get_embedding(face):
    face = cv2.resize(face, (IMG_SIZE, IMG_SIZE))

    gray = cv2.cvtColor(face, cv2.COLOR_BGR2GRAY)
    gray = cv2.equalizeHist(gray)

    edges = cv2.Canny(gray, 50, 150)

    combined = np.hstack((gray.flatten(), edges.flatten()))
    combined = combined.astype("float32")
    combined = combined / np.linalg.norm(combined)

    return combined

# ---------------- MAIN ----------------
print("Building DB...\n")
print("Using videos from:", VIDEO_FOLDER)

for video_file in os.listdir(VIDEO_FOLDER):
    if not video_file.endswith((".mp4", ".avi", ".mov")):
        continue

    person = os.path.splitext(video_file)[0]
    print(f"Processing {person}...")

    cap = cv2.VideoCapture(os.path.join(VIDEO_FOLDER, video_file))

    embeddings = []
    frame_count = 0

    while True:
        ret, frame = cap.read()
        if not ret:
            break

        if frame_count % FRAME_SKIP != 0:
            frame_count += 1
            continue

        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        faces = face_cascade.detectMultiScale(gray, 1.3, 5)

        for (x, y, w, h) in faces:
            face = frame[y:y+h, x:x+w]

            if face.size == 0:
                continue

            for aug_face in augment_face(face):
                if len(embeddings) >= MAX_EMB:
                    break

                try:
                    emb = get_embedding(aug_face)
                    embeddings.append(emb)
                except:
                    continue

        if len(embeddings) >= MAX_EMB:
            break

        frame_count += 1

    cap.release()

    if len(embeddings) > 0:
        centroid = np.mean(embeddings, axis=0)
        centroid = centroid / np.linalg.norm(centroid)

        database[person] = centroid
        print(f"{person}: {len(embeddings)} embeddings")

    else:
        print(f"{person}: No faces detected")

# ---------------- SAVE ----------------
with open(OUTPUT_DB, "wb") as f:
    pickle.dump(database, f)

print("\nSaved DB at:", OUTPUT_DB)